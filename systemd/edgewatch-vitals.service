[Unit]
Description=EdgeWatch Vitals Service
After=network.targetedgewatch-zmq-proxy.service
Requires=edgewatch-zmq-proxy.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/edgewatch
ExecStart=/usr/bin/python3 src/services/vitals_service.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
